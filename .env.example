# --- AtlasAccess environment template ---
# Copy to `.env.local` for local dev. The app is FULLY FUNCTIONAL with no keys:
# the multimodal obstacle reader degrades gracefully to a deterministic rules
# engine when Gemini is unavailable (see src/lib/gemini.ts).

# Toggle the Gemini multimodal path. Leave "false" for offline/local/CI.
USE_GEMINI=false

# --- Option A: Gemini Developer API (simplest, uses an API key) ---
# Obtain from Google AI Studio: https://aistudio.google.com/
GEMINI_API_KEY=

# --- Option B: Vertex AI (production on Cloud Run, uses ADC — no key in repo) ---
# When deployed to Cloud Run, the service account provides credentials.
USE_VERTEX=false
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=us-central1

# Model id
GEMINI_MODEL=gemini-2.5-flash

# --- Real venue data: Google Maps Platform ---
# Enables live venue info (name, address, coordinates, rating and official
# wheelchair-accessibility flags) from the Google Places API, replacing the
# built-in fallback data. Read SERVER-SIDE only — never exposed to the browser.
# Enable the "Places API (New)" in your Google Cloud project and create a key:
# https://console.cloud.google.com/google/maps-apis/  (billing required).
GOOGLE_MAPS_API_KEY=

# --- Optional: nicer map tiles via Mapbox (browser token, referrer-restricted) ---
# When set, the location map uses Mapbox tiles instead of OpenStreetMap.
NEXT_PUBLIC_MAPBOX_TOKEN=
